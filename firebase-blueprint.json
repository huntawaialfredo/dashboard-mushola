{
  "entities": {
    "transaction": {
      "title": "CashTransaction",
      "description": "Transaksi kas masuk dan keluar Masjid Al-Falah",
      "type": "object",
      "properties": {
        "no": {
          "type": "integer",
          "description": "Nomor urut transaksi"
        },
        "tanggal": {
          "type": "string",
          "description": "Tanggal transaksi dalam format DD/MM/YYYY"
        },
        "deskripsi": {
          "type": "string",
          "description": "Deskripsi atau keterangan transaksi"
        },
        "pemasukan": {
          "type": "number",
          "description": "Jumlah pemasukan kas, null jika tidak ada"
        },
        "pengeluaran": {
          "type": "number",
          "description": "Jumlah pengeluaran kas, null jika tidak ada"
        },
        "saldo": {
          "type": "number",
          "description": "Saldo akumulasi berjalan"
        },
        "attachment": {
          "type": "object",
          "description": "Attachment file jika disertakan"
        }
      },
      "required": ["no", "tanggal", "deskripsi"]
    },
    "registeredUser": {
      "title": "RegisteredUser",
      "description": "Akun pengguna terdaftar Sistem Pembukuan Al-Falah",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "Username unik untuk login (huruf kecil)"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "Hak akses akun (admin atau user biasa)"
        },
        "name": {
          "type": "string",
          "description": "Nama lengkap pengguna"
        },
        "password": {
          "type": "string",
          "description": "Kata sandi masuk"
        }
      },
      "required": ["username", "role", "name", "password"]
    }
  },
  "firestore": {
    "transactions": {
      "schema": "transaction",
      "description": "Koleksi seluruh transaksi kas Al-Falah"
    },
    "users": {
      "schema": "registeredUser",
      "description": "Daftar kredensial akun pengguna terdaftar"
    }
  }
}
