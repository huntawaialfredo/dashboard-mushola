rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /transactions/{transactionId} {
      allow read: if true;
      allow write: if true;
    }

    match /users/{username} {
      allow read: if true;
      allow write: if true;
    }

    match /test/{testId} {
      allow read: if true;
    }

    // Default catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
